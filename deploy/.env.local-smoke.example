# LOCAL DOCKER SMOKE TEMPLATE ONLY.
# This example is for the production-like local smoke stack, not for staging or production deployment.
# `localtest.me` resolves to 127.0.0.1, so these hostnames work without editing `/etc/hosts`.
# MUST CHANGE BEFORE USE: generate a unique SECRET_KEY for this smoke environment.
# Smoke/local/staging/production secrets must never be reused.

SECRET_KEY=replace-with-a-strong-64-plus-character-secret
APP_ENV=production
ENABLE_BOOTSTRAP_ADMIN=false
ALLOWED_HOSTS=api.x.localtest.me
CORS_ALLOWED_ORIGINS=http://app.x.localtest.me:3000
NEXT_PUBLIC_API_BASE_URL=http://api.x.localtest.me:8000
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=
# Local/dev only. This bootstrap path is rejected in production.
# BOOTSTRAP_ADMIN_USERNAME=
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_DISPLAY_NAME=

# Email
# Keep capture for local smoke. If you switch to `MAIL_PROVIDER=resend`, you must also set
# a real `RESEND_API_KEY`, a real `MAIL_FROM_EMAIL`, and an https `WEB_BASE_URL`
# that is not localhost or `*.localtest.me`.
MAIL_PROVIDER=capture
MAIL_CAPTURE_DIR=tmp/mail
RESEND_API_KEY=
MAIL_FROM_EMAIL=no-reply@localhost
MAIL_FROM_NAME=Nexus
WEB_BASE_URL=http://localhost:3000
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@x.localtest.me
