# LOCAL BACKEND DEVELOPMENT ONLY.
# Do not use this file for Docker smoke, staging, or production deployments.
# MUST CHANGE BEFORE USE: `SECRET_KEY` below is a placeholder and must stay unique to this local environment.
# Production/staging/smoke/local must never share the same `SECRET_KEY`.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xplatform
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=replace-with-a-local-dev-secret-before-running
APP_ENV=development
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENABLE_BOOTSTRAP_ADMIN=false
# Local/dev only. Requires all three runtime values and is rejected in production.
# BOOTSTRAP_ADMIN_USERNAME=
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_DISPLAY_NAME=
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_SECURE=
REFRESH_COOKIE_DOMAIN=
# Development example only. For the production-like Docker smoke path, use deploy/.env.local-smoke.example.
# Do not copy localhost hosts or secrets from this file into staging or production.
CORS_ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=
UPLOADS_CACHE_CONTROL=public, max-age=3600

# Email
# Use capture for local development unless you explicitly configure a real provider.
MAIL_PROVIDER=capture
MAIL_CAPTURE_DIR=tmp/mail

# Real provider settings (example placeholders)
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM_EMAIL=no-reply@yourdomain.com
MAIL_FROM_NAME=Nexus
WEB_BASE_URL=https://yourdomain.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@example.com
